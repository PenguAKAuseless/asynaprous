# AsynapRous local environment example
# Copy this file to .env and replace all values.

# SQLite database path (absolute path or path relative to repo root)
ASYNAPROUS_DB_PATH=db/asynaprous.sqlite3

# Extra secret mixed into password hashing (change for your environment)
ASYNAPROUS_AUTH_PEPPER=replace-with-long-random-pepper

# Session cookie policy: auto uses TLS/Forwarded headers, true always sets Secure.
ASYNAPROUS_COOKIE_SECURE=auto

# Print warning when Basic auth is accepted over non-TLS transport.
ASYNAPROUS_WARN_INSECURE_AUTH=true

# Optional TLS for backend listener (sample app / backend).
# For HTTPS local demo, set both cert and key paths.
# ASYNAPROUS_TLS_CERT_FILE=cert/server.crt
# ASYNAPROUS_TLS_KEY_FILE=cert/server.key

# Optional TLS for proxy listener.
# ASYNAPROUS_PROXY_TLS_CERT_FILE=cert/server.crt
# ASYNAPROUS_PROXY_TLS_KEY_FILE=cert/server.key

# Optional TLS for peer-to-peer chat forwarding.
ASYNAPROUS_PEER_TLS=false
ASYNAPROUS_PEER_TLS_VERIFY=false
# ASYNAPROUS_PEER_TLS_CA_FILE=cert/ca.crt

# Optional TLS for proxy-to-backend upstream forwarding.
ASYNAPROUS_PROXY_UPSTREAM_TLS=false
ASYNAPROUS_PROXY_UPSTREAM_TLS_VERIFY=false
# ASYNAPROUS_PROXY_UPSTREAM_TLS_CA_FILE=cert/ca.crt

# Demo users seeded on first run if account row does not exist yet
ASYNAPROUS_DEMO_PASSWORD_ADMIN=replace-admin-password
ASYNAPROUS_DEMO_PASSWORD_USER1=replace-user1-password
ASYNAPROUS_DEMO_PASSWORD_USER2=replace-user2-password
ASYNAPROUS_DEMO_PASSWORD_USER3=replace-user3-password
ASYNAPROUS_DEMO_PASSWORD_USER4=replace-user4-password
ASYNAPROUS_DEMO_PASSWORD_USER5=replace-user5-password
